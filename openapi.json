      "CameraEvent": {
        "properties": {
          "event_id": {
            "type": "string",
            "format": "uuid",
            "title": "Event Id",
            "description": "Unique identifier for the event"
          },
          "venue_id": {
            "type": "string",
            "title": "Venue Id",
            "description": "The unique ID of the venue (e.g., elsewhere-brooklyn)"
          },
          "source_type": {
            "$ref": "#/components/schemas/SourceType",
            "default": "camera"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "When the event occurred at the source"
          },
          "received_at": {
            "type": "string",
            "format": "date-time",
            "title": "Received At",
            "description": "When the event hit our ingestion API"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata",
            "description": "Arbitrary source metadata (firmware, sensor IDs, etc.)"
          },
          "payload": {
            "$ref": "#/components/schemas/CameraEventPayload"
          }
        },
        "type": "object",
        "required": [
          "venue_id",
          "payload"
        ],
        "title": "CameraEvent"
      },
      "CameraEventPayload": {
        "properties": {
          "zone_id": {
            "type": "string",
            "title": "Zone Id"
          },
          "person_count": {
            "type": "integer",
            "title": "Person Count"
          },
          "detections": {
            "items": {
              "$ref": "#/components/schemas/Detection"
            },
            "type": "array",
            "title": "Detections"
          },
          "aggression_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Aggression Score",
            "default": 0.0
          },
          "anomaly_detected": {
            "type": "boolean",
            "title": "Anomaly Detected",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "zone_id",
          "person_count",
          "detections"
        ],
        "title": "CameraEventPayload"
      },
      "Citation": {
        "properties": {
          "source_id": {
            "type": "string",
            "title": "Source Id"
          },
          "source_type": {
            "type": "string",
            "title": "Source Type"
          },
          "excerpt": {
            "type": "string",
            "title": "Excerpt"
          }
        },
        "type": "object",
        "required": [
          "source_id",
          "source_type",
          "excerpt"
        ],
        "title": "Citation"
      },
      "ComplianceItem": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "severity": {
            "type": "string",
            "title": "Severity"
          }
        },
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "severity"
        ],
        "title": "ComplianceItem"
      },
      "Detection": {
        "properties": {
          "label": {
            "type": "string",
            "title": "Label"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "box": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "title": "Box"
          }
        },
        "type": "object",
        "required": [
          "label",
          "confidence",
          "box"
        ],
        "title": "Detection"
      },
