# ThirdSpaceRisk / NightlineRisk backend — environment variables.
# Copy to .env (or set in your host's dashboard). Only APP_SECRET and
# DATABASE_URL matter for a basic run; everything else gates an optional
# feature and degrades gracefully when unset.

# ── Required in production ───────────────────────────────────────────────
# Stable secret used to sign session tokens. If unset in production the app
# refuses to start (see app/config.py); in dev it falls back to an ephemeral
# per-process secret and logs a warning (sessions reset on restart).
APP_SECRET=

# Database URI. Unset → falls back to local SQLite. Use the Postgres URL in prod.
DATABASE_URL=

# Marks the environment as production. Railway sets RAILWAY_ENVIRONMENT
# automatically; set APP_ENV=production on other hosts.
APP_ENV=

# ── Storage ──────────────────────────────────────────────────────────────
# "local" (default) writes uploads to ./evidence_uploads — EPHEMERAL on hosts
# with a non-persistent filesystem (e.g. Railway), so evidence + defense PDFs
# vanish on redeploy. "s3" uses any S3-compatible object store (AWS S3,
# Cloudflare R2, Backblaze B2). When STORAGE_BACKEND=s3, all four S3_* vars are
# required or the app fails fast at first storage use.
STORAGE_BACKEND=local
# S3-compatible endpoint. For Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Region: R2 uses "auto" (default); AWS S3 uses e.g. "us-east-1".
S3_REGION=auto

# ── Email (password reset, etc.) ─────────────────────────────────────────
# Resend API key. Unset → reset emails are disabled and the reset URL is logged
# instead (dev-friendly). FRONTEND_URL is the base for links in emails.
RESEND_API_KEY=
FRONTEND_URL=http://localhost:3000

# ── AI providers (unset → deterministic fallback) ────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Copilot LLM (any OpenAI-compatible endpoint; unset → deterministic) ───
# Open-source, keyless-capable upgrade for the /copilot conversational layer.
# Works with Ollama (local, no key), Groq (free tier), OpenRouter, vLLM, etc.
# Takes precedence over ANTHROPIC_API_KEY for the copilot. Faithfulness guard
# still applies, so the model can only answer from the venue-gated tools.
#   Ollama (local):  COPILOT_LLM_BASE_URL=http://localhost:11434/v1
#                    COPILOT_LLM_MODEL=llama3.1:8b        (no key)
#   Groq (free):     COPILOT_LLM_BASE_URL=https://api.groq.com/openai/v1
#                    COPILOT_LLM_MODEL=llama-3.3-70b-versatile
#                    COPILOT_LLM_API_KEY=gsk_...
COPILOT_LLM_BASE_URL=
COPILOT_LLM_MODEL=
COPILOT_LLM_API_KEY=

# ── Web push notifications (unset → push delivery skipped) ───────────────
VAPID_PRIVATE_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────
# Extra browser origins allowed for CORS, comma-separated. Standard localhost:3000
# (+ 127.0.0.1) and prod (*.vercel.app) are always allowed; use this for a phone on
# the LAN or a local verify server on a non-3000 port — no source edit needed.
# Example: EXTRA_CORS_ORIGINS=http://192.168.1.5:3000,http://localhost:4321
EXTRA_CORS_ORIGINS=

# ── Misc feature gates ───────────────────────────────────────────────────
# Background ingestion tick interval in seconds (unset → disabled).
INGEST_TICK_SECONDS=
# Policy document parser: "regex" (default) or "pageindex".
POLICY_PARSER=

# ── Comms connectors: real MCP sources (unset → simulated source) ────────
# Nightline pulls comms items (Slack / tickets / SMS) over the MCP-client seam.
# Set a source's SSE URL to point its CommsSource at a live MCP server's
# list_items tool; leave unset to use the deterministic simulated source.
COMMS_MCP_SLACK_SSE_URL=
COMMS_MCP_TICKETS_SSE_URL=
COMMS_MCP_SMS_SSE_URL=
